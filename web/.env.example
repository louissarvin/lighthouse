# ════════════════════════════════════════════════════════════════════
# LIGHTHOUSE WEB .env.example
# Copy to .env and fill in your values.
# Only VITE_ prefixed vars are exposed to the browser.
# NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════════════

# === BACKEND URL ===
# The Lighthouse backend API. Default points to local dev server.
VITE_API_BASE_URL=http://localhost:3700

# === TELEGRAM BOT ===
# Public URL for the "Open bot" CTA links.
VITE_TELEGRAM_BOT_URL=https://t.me/LighthouseCoachBot

# === SERVER-SIDE ONLY (not exposed to browser) ===
# Used by TanStack Start SSR if needed. Leave blank for pure SPA mode.
# SERVER_URL=

# === ENOKI / zkLogin (client-side signing) ===
# Both must belong to the SAME Enoki app as the backend's ENOKI_PRIVATE_KEY.
# The Google client ID must also match the backend's OAuth client exactly —
# mismatches produce a different derived Sui address.
VITE_ENOKI_PUBLIC_KEY=enoki_public_REPLACE_ME
VITE_GOOGLE_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com
