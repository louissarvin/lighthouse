{
  "name": "lighthouse-backend",
  "version": "0.1.0",
  "main": "index.ts",
  "type": "module",
  "description": "Lighthouse backend: CoachOrchestrator + SettlementKeeper + EventIndexer + EnokiSponsor + TelegramAuth",
  "scripts": {
    "start": "bun index.ts",
    "dev": "bun --watch index.ts",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "db:push": "bunx prisma db push --config prisma/prisma.config.ts && bunx prisma generate --config prisma/prisma.config.ts",
    "db:pull": "bunx prisma db pull --config prisma/prisma.config.ts",
    "db:generate": "bunx prisma generate --config prisma/prisma.config.ts",
    "db:migrate": "bunx prisma migrate dev --name init --config prisma/prisma.config.ts",
    "smoke": "bun run scripts/smoke.ts",
    "smoke:live": "bun run scripts/smoke.ts --mode=live",
    "setup-bot": "bun run scripts/setup-telegram-bot.ts",
    "setup-bot:dry": "bun run scripts/setup-telegram-bot.ts --dry-run"
  },
  "keywords": ["sui", "walrus", "deepbook", "memwal", "seal", "atoma"],
  "license": "Apache-2.0",
  "dependencies": {
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/rate-limit": "^11.0.0",
    "@mysten-incubation/memwal": "0.0.7",
    "@mysten/bcs": "^2.0.3",
    "@mysten/deepbook-v3": "^1.4.1",
    "@mysten/enoki": "^1.0.0",
    "@mysten/seal": "1.1.3",
    "@mysten/sui": "^2.19.0",
    "@mysten/sui-groups": "0.0.1",
    "@mysten/sui-stack-messaging": "0.0.2",
    "@mysten/suins": "^1.1.4",
    "@mysten/walrus": "^1.1.7",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "atoma-sdk": "^0.2.1",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "fastify": "^5.6.0",
    "grammy": "^1.30.0",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.0.9",
    "node-cron": "^3.0.3",
    "pg": "^8.13.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.10",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.0",
    "bun-types": "latest",
    "eslint": "^8.57.0",
    "prisma": "^7.0.0",
    "typescript": "^5.7.3"
  }
}
