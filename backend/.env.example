# === 13. ATOMA ===
ATOMASDK_BEARER_AUTH=
ATOMA_DEFAULT_MODEL=meta-llama/Llama-3.3-70B-Instruct
COACH_CONFIDENTIAL=0
# Optional Groq fallback
GROQ_API_KEY=

# === 14. SUI STACK MESSAGING ===
# Run the relayer locally via Docker — see README for setup steps.
RELAYER_URL=http://localhost:3000

# === 15. GOOGLE OAUTH ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === 16. ENOKI / ZKLOGIN ===
ENOKI_PRIVATE_KEY=
ZKLOGIN_PROVER_URL=https://prover-dev.mystenlabs.com/v1
OAUTH_CALLBACK=http://localhost:3700/oauth/callback

# === 17. TELEGRAM BOT ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=LighthouseCoachBot
# Generate: openssl rand -hex 32
TG_USER_ID_PEPPER=
# Required in production; generate: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET_TOKEN=
# Set to 1 for local long-polling instead of webhook
TG_BOT_POLLING=1

# === 18. WEB ORIGIN ===
WEB_BASE_URL=http://localhost:3200

# === 19. COACH + INDEXER TUNING ===
COACH_GUARDIAN_MAX_SLIPPAGE_BPS=100
COACH_GUARDIAN_MARKET_FRESHNESS_MS=5000
EVENT_INDEXER_RECONNECT_MS=3000
