# ════════════════════════════════════════════════════════════════════
# LIGHTHOUSE BACKEND .env.example (LOCAL — NEVER COMMIT .env)
# Copy to .env and fill in the blanked credentials.
# All public IDs and constants are pre-filled from testnet.
# Source of truth for IDs: memory/LIGHTHOUSE_BACKEND_TESTNET_CONSTANTS.md
# ════════════════════════════════════════════════════════════════════

# === 1. SERVER ===
APP_PORT=3700
NODE_ENV=development

# === 2. DATABASE ===
# Replace <your-password> with your local PostgreSQL password.
DATABASE_URL="postgresql://postgres:<your-password>@localhost:5432/lighthouse?schema=public"

# === 3. JWT AUTH ===
# Generate: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=7d

# === 4. SUI NETWORK ===
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# === 5. LIGHTHOUSE MOVE PACKAGE (upgraded 2026-06-19) ===
# Tx digest: 2xCRLKhCWQn1MVKKUVP3uPT4ryXcnxZo8S2RSsN4HLr9 (v3, links DeepBook testnet-v17)
# Previous publish: 9n3rLan2K7jMr4toG6k2qw2hEEmLz2KS1pK2PuuQQFHe (2026-06-17, v1)
# Full deploy log: memory/LIGHTHOUSE_TESTNET_DEPLOY_2026_06_17.md
LIGHTHOUSE_PACKAGE_ID=0x3865cee0905149480eb3394e6e31aa709093b5134d49e9e701cf4565d5822831
LIGHTHOUSE_UPGRADE_CAP_ID=0x43ee29bf12e2a0c89a83ab47d59be76831c2a1b8436907c2f8a5be07a1f0a0bf
