LIGHTHOUSE_VERSION_OBJECT_ID=0x3b989979ca29e58d39e547687d5538f49ac7db463565111d8a6fd909ac2e78aa

# === 6. BACKEND KEYPAIRS ===
# Bech32 suiprivkey1... format. Generate via: sui keytool generate ed25519
COACH_AGENT_PRIVATE_KEY=
EXECUTOR_AGENT_PRIVATE_KEY=
SETTLEMENT_KEEPER_PRIVATE_KEY=

# === 7. WALRUS (testnet) ===
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_UPLOAD_RELAY_HOST=https://upload-relay.testnet.walrus.space
WALRUS_DEFAULT_EPOCHS=53

# === 8. SEAL (testnet) ===
SEAL_PACKAGE_ID=0xdccbeb87767be2b2346af5575eb139807205e4c23ec53dc616f951fe1d814112
SEAL_KEY_SERVER_IDS=0x73d05d62c18d9374e3ea529e8e0ed6161da1a141a94d3f76ae3fe4e99356db75,0xf5d14a81a982144ae441cd7d64b09027f116a468bd36e7eca494f750591623c8,0x6068c0acb197dddbacd4746a9de7f025b2ed5a5b6c1b1ab44dade4426d141da2
SEAL_AGGREGATOR_URL=https://seal-aggregator-testnet.mystenlabs.com

# === 9. MEMWAL (testnet) ===
MEMWAL_RELAYER_URL=https://relayer-staging.memory.walrus.xyz
MEMWAL_PACKAGE_ID=0xcf6ad755a1cdff7217865c796778fabe5aa399cb0cf2eba986f4b582047229c6
MEMWAL_REGISTRY_ID=0xe80f2feec1c139616a86c9f71210152e2a7ca552b20841f2e192f99f75864437
# Generate: openssl rand -hex 32
MEMWAL_DELEGATE_ENCRYPTION_KEY=

# === 10. CACHE TUNING ===
EXECUTOR_AGENT_CACHE_TTL_MS=60000

# === 11. DEEPBOOK V3 (testnet, canonical original deploy) ===
# 0x22be4c... is the original DeepBook publish (upgrade root). Pool allowed_versions
# = {1..5}; Lighthouse is now pinned to testnet-v17 (CURRENT_VERSION=5). Do NOT
# use 0x74cd5657 (testnet-v19, CURRENT_VERSION=8) — causes EPackageVersionDisabled.
DEEPBOOK_PACKAGE_ID=0x22be4cade64bf2d02412c7e8d0e8beea2f78828b948118d46735315409371a3c
DEEPBOOK_REGISTRY_ID=0x7c256edbda983a2cd6f946655f4bf3f00a41043993781f8674a7046e8c0e11d1
